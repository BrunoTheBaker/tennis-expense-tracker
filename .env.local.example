# Reckon Integration
RECKON_API_KEY=your_reckon_api_key_here
RECKON_ORGANISATION_ID=your_organisation_id_here
RECKON_ENVIRONMENT=sandbox

# Optional: Email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# AI Cost Centre Suggestion
ANTHROPIC_API_KEY=sk-ant-...   # Required for AI cost centre suggestions

# Optional: File upload storage
UPLOAD_STORAGE=local
AWS_S3_BUCKET=your_bucket_name
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret